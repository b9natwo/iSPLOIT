--  INTRO
-- ══════════════════════════════════════════════════════════════════════════════
local function PlayIntro(gui, onDone)
    local overlay = New("Frame", {
        Name             = "IntroOverlay",
        Size             = UDim2.fromScale(1, 1),
        Position         = UDim2.fromScale(0, 0),
        BackgroundColor3 = C.WHITE,
        BorderSizePixel  = 0,
        ZIndex           = 500,
        Parent           = gui,
    })

    local pivot = New("Frame", {
        AnchorPoint          = Vector2.new(0.5, 0.5),
        Position             = UDim2.fromScale(0.5, 0.5),
        Size                 = UDim2.fromOffset(140, 200),
        BackgroundTransparency = 1,
        ZIndex               = 501,
        Parent               = overlay,
    })

    local arcDefs = {
        { sz = 120, thick = 4.5, speed =  90  },
        { sz =  82, thick = 3.5, speed = -130 },
        { sz =  48, thick = 2.5, speed =  175 },
    }
    local arcs = {}
    for _, ad in ipairs(arcDefs) do
        local arc = New("Frame", {
            AnchorPoint          = Vector2.new(0.5, 0),
            Position             = UDim2.new(0.5, 0, 0, 0),
            Size                 = UDim2.fromOffset(ad.sz, ad.sz),
            BackgroundTransparency = 1,
            ZIndex               = 502,
            Parent               = pivot,
        })
        Corner(ad.sz / 2, arc)
        local st = Stroke(ad.thick, Color3.fromRGB(255, 0, 0), arc)

        local inner = New("Frame", {
            AnchorPoint      = Vector2.new(0.5, 0.5),
            Position         = UDim2.fromScale(0.5, 0.5),
            Size             = UDim2.fromOffset(ad.sz - ad.thick * 2 - 2, ad.sz - ad.thick * 2 - 2),
            BackgroundColor3 = C.WHITE,
            ZIndex           = 503,
            Parent           = arc,
        })
        Corner(ad.sz / 2, inner)

        local wedge = New("Frame", {
            AnchorPoint      = Vector2.new(0.5, 1),
            Position         = UDim2.new(0.5, 0, 0, 0),
            Size             = UDim2.fromOffset(ad.thick + 4, ad.sz / 2 + 2),
            BackgroundColor3 = C.WHITE,
            ZIndex           = 504,
            Parent           = arc,
        })

        table.insert(arcs, { arc = arc, inner = inner, wedge = wedge, stroke = st, speed = ad.speed })
    end

    local spinConn = RunService.Heartbeat:Connect(function(dt)
        local col = Color3.fromHSV(rgbHue, 1, 1)
        for _, a in ipairs(arcs) do
            if a.arc and a.arc.Parent then
                a.arc.Rotation = a.arc.Rotation + a.speed * dt
                a.stroke.Color = col
            end
        end
    end)

    local logo = New("TextLabel", {
        AnchorPoint          = Vector2.new(0.5, 0),
        Position             = UDim2.new(0.5, 0, 0, 128),
        Size                 = UDim2.fromOffset(200, 34),
        BackgroundTransparency = 1,
        Text                 = "iSPLOIT",
        Font                 = Enum.Font.Code,
        TextSize             = 26,
        TextColor3           = Color3.fromRGB(255, 0, 0),
        TextXAlignment       = Enum.TextXAlignment.Center,
        ZIndex               = 502,
        Parent               = pivot,
    })
    AddRGB(logo, "TextColor3")

    local sub = New("TextLabel", {
        AnchorPoint          = Vector2.new(0.5, 0),
        Position             = UDim2.new(0.5, 0, 0, 165),
        Size                 = UDim2.fromOffset(200, 16),
        BackgroundTransparency = 1,
        Text                 = "UI LIBRARY  v1.2",
        Font                 = Enum.Font.GothamMedium,
        TextSize             = 9,
        TextColor3           = C.T_HINT,
        TextXAlignment       = Enum.TextXAlignment.Center,
        ZIndex               = 502,
        Parent               = pivot,
    })

    task.delay(2.5, function()
        spinConn:Disconnect()
        RemoveRGB(logo)
        TweenService:Create(overlay, TweenInfo.new(0.55, Enum.EasingStyle.Quart), {BackgroundTransparency = 1}):Play()
        TweenService:Create(logo, TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        TweenService:Create(sub,  TweenInfo.new(0.4), {TextTransparency = 1}):Play()
        for _, a in ipairs(arcs) do
            TweenService:Create(a.stroke, TweenInfo.new(0.4), {Transparency = 1}):Play()
            TweenService:Create(a.inner,  TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
            TweenService:Create(a.wedge,  TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        end
        task.delay(0.65, function()
            overlay:Destroy()
            if onDone then onDone() end
        end)
    end)
end


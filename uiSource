        local sideTabVL = VList(2, sideTabF)
        sideTabVL.Changed:Connect(function()
            sideTabF.Size = UDim2.new(1, 0, 0, sideTabVL.AbsoluteContentSize.Y + 4)
        end)

        -- ── FIX: sideItems is per-tab, NOT a shared global ────────────────────
        -- Previously allSide was one flat list shared by all tabs.
        -- Now each tab entry owns its own list so activating a sidebar item
        -- only deactivates siblings within the same tab.
        local tabEntry = {
            btn       = tbtn,
            lbl       = tbtnLbl,
            page      = page,
            sideF     = sideTabF,
            sideItems = {},      -- ← per-tab list of { lbl, bar }
        }
        table.insert(allTabs, tabEntry)

        -- Tab click: hide everything, show this tab's page + sidebar group
        tbtn.MouseButton1Click:Connect(function()
            for _, te in ipairs(allTabs) do
                TweenService:Create(te.btn, T_SHORT, { BackgroundTransparency = 1 }):Play()
                TweenService:Create(te.lbl, T_SHORT, { TextColor3 = C.T_HINT }):Play()
                te.page.Visible  = false
                te.sideF.Visible = false
            end
            TweenService:Create(tbtn,    T_SHORT, { BackgroundTransparency = 0 }):Play()
            TweenService:Create(tbtnLbl, T_SHORT, { TextColor3 = C.T_PRI }):Play()
            page.Visible     = true
            sideTabF.Visible = true
        end)

        -- ── Tab object ────────────────────────────────────────────────────────
        local Tab = {}

        -- ════════════════════════════════════════════════════════════════════
        --  CREATE SECTION
        -- ════════════════════════════════════════════════════════════════════
        function Tab:CreateSection(secName)

            -- Sidebar item for this section
            local si = New("TextButton", {
                Size                 = UDim2.new(1, 0, 0, 30),
                BackgroundTransparency = 1,
                Text                 = "",
                ZIndex               = 14,
                Parent               = sideTabF,   -- goes into THIS tab's sidebar group
            })
            local siBar = New("Frame", {
                AnchorPoint      = Vector2.new(0, 0.5),
                Position         = UDim2.new(0, 0, 0.5, 0),
                Size             = UDim2.fromOffset(3, 16),
                BackgroundColor3 = Color3.fromRGB(255, 0, 0),
                BackgroundTransparency = 1,
                BorderSizePixel  = 0,
                ZIndex           = 15,
                Parent           = si,
            })
            Corner(2, siBar)
            local siLbl = New("TextLabel", {
                Position         = UDim2.new(0, 12, 0, 0),
                Size             = UDim2.new(1, -12, 1, 0),
                BackgroundTransparency = 1,
                Text             = secName,
                Font             = Enum.Font.Gotham,
                TextSize         = 12,
                TextColor3       = C.T_HINT,
                TextXAlignment   = Enum.TextXAlignment.Left,
                ZIndex           = 15,
                Parent           = si,
            })

            -- Section card in the content page
            local card = New("Frame", {
                Size             = UDim2.new(1, 0, 0, 0),
                BackgroundColor3 = Color3.fromRGB(250, 250, 250),
                AutomaticSize    = Enum.AutomaticSize.Y,
                ClipsDescendants = false,
                ZIndex           = 12,
                Parent           = page,   -- goes into THIS tab's page
            })
            Corner(10, card)
            Stroke(1, Color3.fromRGB(238, 238, 238), card)
            Pad(10, 12, 12, 12, card)
            VList(8, card)

            -- Section header
            local hdr = New("Frame", { Size=UDim2.new(1,0,0,18), BackgroundTransparency=1, ZIndex=13, Parent=card })
            local hdrDot = New("Frame", { AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,0,0.5,0), Size=UDim2.fromOffset(6,6), BackgroundColor3=Color3.fromRGB(255,0,0), BorderSizePixel=0, ZIndex=14, Parent=hdr })
            Corner(3, hdrDot); AddRGB(hdrDot, "BackgroundColor3")
            New("TextLabel", { Position=UDim2.fromOffset(14,0), Size=UDim2.new(1,-14,1,0), BackgroundTransparency=1, Text=string.upper(secName), Font=Enum.Font.GothamBold, TextSize=10, TextColor3=C.T_HINT, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=14, Parent=hdr })
            New("Frame", { Size=UDim2.new(1,0,0,1), BackgroundColor3=C.DIVIDER, BorderSizePixel=0, ZIndex=13, Parent=card })

            table.insert(tabEntry.sideItems, { lbl = siLbl, bar = siBar })

            -- ── FIX: first-section check is scoped to this tab ────────────────
            if #tabEntry.sideItems == 1 then
                siLbl.TextColor3         = C.T_PRI
                siLbl.Font               = Enum.Font.GothamBold
                siBar.BackgroundTransparency = 0
                AddRGB(siBar, "BackgroundColor3")
            end

            -- Sidebar click: scroll to the section card
            si.MouseButton1Click:Connect(function()
                -- Deactivate all sidebar items in THIS TAB ONLY
                for _, s in ipairs(tabEntry.sideItems) do
                    TweenService:Create(s.lbl, T_SHORT, { TextColor3 = C.T_HINT, Font = Enum.Font.Gotham }):Play()
                    TweenService:Create(s.bar, T_SHORT, { BackgroundTransparency = 1 }):Play()
                end
                -- Activate this one
                TweenService:Create(siLbl, T_SHORT, { TextColor3 = C.T_PRI, Font = Enum.Font.GothamBold }):Play()
                TweenService:Create(siBar, T_SHORT, { BackgroundTransparency = 0 }):Play()
                AddRGB(siBar, "BackgroundColor3")
                -- Scroll page to card
                local ty = card.AbsolutePosition.Y - page.AbsolutePosition.Y + page.CanvasPosition.Y - 10
                TweenService:Create(page, T_MED, { CanvasPosition = Vector2.new(0, math.max(0, ty)) }):Play()
            end)

            -- ── Section object ────────────────────────────────────────────────
            local Section = {}

            -- ── TOGGLE ───────────────────────────────────────────────────────
            function Section:CreateToggle(cfg2)
                cfg2 = cfg2 or {}
                local nm, def, cb = cfg2.Name or "Toggle", cfg2.Default or false, cfg2.Callback or function() end
                local row = New("Frame", { Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, ZIndex=14, Parent=card })
                New("TextLabel", { Size=UDim2.new(1,-50,1,0), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15, Parent=row })
                local tbg = New("TextButton", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.fromOffset(40,22), BackgroundColor3=def and Color3.fromRGB(0,200,100) or Color3.fromRGB(215,215,215), Text="", ZIndex=15, Parent=row })
                Corner(11, tbg)
                local tth = New("Frame", { AnchorPoint=Vector2.new(0,0.5), Position=UDim2.fromOffset(def and 20 or 2, 11), Size=UDim2.fromOffset(18,18), BackgroundColor3=C.WHITE, ZIndex=16, Parent=tbg })
                Corner(9, tth)
                local state = def
                if state then AddRGB(tbg, "BackgroundColor3") end
                tbg.MouseButton1Click:Connect(function()
                    state = not state
                    if state then
                        AddRGB(tbg, "BackgroundColor3")
                        TweenService:Create(tth, T_SPRING, { Position=UDim2.fromOffset(20,11) }):Play()
                    else
                        RemoveRGB(tbg)
                        TweenService:Create(tbg, T_SHORT, { BackgroundColor3=Color3.fromRGB(215,215,215) }):Play()
                        TweenService:Create(tth, T_SPRING, { Position=UDim2.fromOffset(2,11) }):Play()
                    end
                    cb(state)
                end)
                local T2 = {}
                function T2:Set(v)
                    state = v
                    if state then AddRGB(tbg,"BackgroundColor3"); tth.Position=UDim2.fromOffset(20,11)
                    else RemoveRGB(tbg); tbg.BackgroundColor3=Color3.fromRGB(215,215,215); tth.Position=UDim2.fromOffset(2,11) end
                    cb(state)
                end
                function T2:Get() return state end
                return T2
            end

            -- ── SLIDER ───────────────────────────────────────────────────────
            function Section:CreateSlider(cfg2)
                cfg2 = cfg2 or {}
                local nm  = cfg2.Name    or "Slider"
                local mn  = cfg2.Min     or 0
                local mx  = cfg2.Max     or 100
                local def = cfg2.Default or mn
                local sfx = cfg2.Suffix  or ""
                local cb  = cfg2.Callback or function() end
                local cont = New("Frame", { Size=UDim2.new(1,0,0,44), BackgroundTransparency=1, ZIndex=14, Parent=card })
                local top  = New("Frame", { Size=UDim2.new(1,0,0,20), BackgroundTransparency=1, ZIndex=15, Parent=cont })
                New("TextLabel", { Size=UDim2.new(1,-62,1,0), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=16, Parent=top })
                local vlbl = New("TextLabel", { AnchorPoint=Vector2.new(1,0), Position=UDim2.fromScale(1,0), Size=UDim2.fromOffset(60,20), BackgroundTransparency=1, Text=tostring(def)..sfx, Font=Enum.Font.Code, TextSize=11, TextColor3=C.T_HINT, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=16, Parent=top })
                local trk = New("Frame", { Position=UDim2.fromOffset(0,26), Size=UDim2.new(1,0,0,4), BackgroundColor3=Color3.fromRGB(228,228,228), ZIndex=15, Parent=cont })
                Corner(2, trk)
                local p0 = (def - mn) / (mx - mn)
                local fill = New("Frame", { Size=UDim2.fromScale(p0,1), BackgroundColor3=Color3.fromRGB(255,0,0), ZIndex=16, Parent=trk })
                Corner(2, fill); AddRGB(fill, "BackgroundColor3")
                local thumb = New("Frame", { AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(p0,0,0.5,0), Size=UDim2.fromOffset(14,14), BackgroundColor3=C.WHITE, ZIndex=17, Parent=trk })
                Corner(7, thumb); Stroke(1.5, Color3.fromRGB(205,205,205), thumb)
                local val, dragging = def, false
                local function upd(ax)
                    local p = math.clamp((ax - trk.AbsolutePosition.X) / trk.AbsoluteSize.X, 0, 1)
                    val = math.floor(mn + p * (mx - mn) + 0.5)
                    local vp = (val - mn) / (mx - mn)
                    fill.Size = UDim2.fromScale(vp, 1)
                    thumb.Position = UDim2.new(vp, 0, 0.5, 0)
                    vlbl.Text = tostring(val) .. sfx
                    cb(val)
                end
                trk.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true; upd(i.Position.X) end end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
                UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
                local SL = {}
                function SL:Set(v)
                    val = math.clamp(v, mn, mx)
                    local vp = (val - mn) / (mx - mn)
                    fill.Size = UDim2.fromScale(vp, 1); thumb.Position = UDim2.new(vp,0,0.5,0); vlbl.Text = tostring(val)..sfx; cb(val)
                end
                function SL:Get() return val end
                return SL
            end

            -- ── DROPDOWN (portal-based) ───────────────────────────────────────
            function Section:CreateDropdown(cfg2)
                cfg2 = cfg2 or {}
                local nm   = cfg2.Name    or "Dropdown"
                local opts = cfg2.Options or {}
                local def  = cfg2.Default or (opts[1] or "")
                local cb   = cfg2.Callback or function() end
                local ROW_H, MAX_H = 28, 140

                local row = New("Frame", { Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, ZIndex=14, Parent=card })
                New("TextLabel", { Size=UDim2.new(0.38,0,1,0), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15, Parent=row })
                local ddBtn = New("TextButton", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.new(0.60,0,0,26), BackgroundColor3=C.SURFACE, Text="", ZIndex=15, Parent=row })
                Corner(6, ddBtn); Stroke(1, Color3.fromRGB(228,228,228), ddBtn)
                local ddVal = New("TextLabel", { Position=UDim2.fromOffset(9,0), Size=UDim2.new(1,-26,1,0), BackgroundTransparency=1, Text=def, Font=Enum.Font.Gotham, TextSize=12, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=16, Parent=ddBtn })
                local arrow = New("TextLabel", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-8,0.5,0), Size=UDim2.fromOffset(12,12), BackgroundTransparency=1, Text="▾", Font=Enum.Font.Gotham, TextSize=10, TextColor3=C.T_HINT, ZIndex=16, Parent=ddBtn })

                local menu = New("Frame", { Size=UDim2.fromOffset(1,0), BackgroundColor3=C.WHITE, ClipsDescendants=true, Visible=false, ZIndex=401, Parent=ddPortal })
                Corner(8, menu); Stroke(1, C.BORDER, menu)
                local menuScroll = New("ScrollingFrame", { Size=UDim2.fromScale(1,1), BackgroundTransparency=1, ScrollBarThickness=3, ScrollBarImageColor3=Color3.fromRGB(200,200,200), CanvasSize=UDim2.fromScale(0,0), ZIndex=402, Parent=menu })
                local menuVL = VList(0, menuScroll)
                menuVL.Changed:Connect(function() menuScroll.CanvasSize = UDim2.fromOffset(0, menuVL.AbsoluteContentSize.Y) end)

                local selected, isOpen = def, false

                local function closeMenu()
                    isOpen = false
                    TweenService:Create(menu, T_SHORT, { Size=UDim2.fromOffset(menu.AbsoluteSize.X, 0) }):Play()
                    TweenService:Create(arrow, T_SHORT, { Rotation=0 }):Play()
                    task.delay(0.22, function() menu.Visible = false end)
                end

                local function buildOpts()
                    for _, c in ipairs(menuScroll:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _, opt in ipairs(opts) do
                        local isSel = (opt == selected)
                        local ob = New("TextButton", { Size=UDim2.new(1,0,0,ROW_H), BackgroundColor3=isSel and Color3.fromRGB(244,244,244) or C.WHITE, BackgroundTransparency=0, Text="", ZIndex=403, Parent=menuScroll })
                        Pad(0, 10, 0, 10, ob)
                        New("TextLabel", { Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text=opt, Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham, TextSize=12, TextColor3=isSel and C.T_PRI or C.T_SEC, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=404, Parent=ob })
                        if isSel then New("TextLabel", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-10,0.5,0), Size=UDim2.fromOffset(14,14), BackgroundTransparency=1, Text="✓", Font=Enum.Font.GothamBold, TextSize=11, TextColor3=Color3.fromRGB(0,176,255), ZIndex=404, Parent=ob }) end
                        Hover(ob, isSel and Color3.fromRGB(244,244,244) or C.WHITE, Color3.fromRGB(240,240,240))
                        ob.MouseButton1Click:Connect(function()
                            selected = opt; ddVal.Text = opt; cb(opt)
                            closeMenu(); task.delay(0.05, buildOpts)
                        end)
                    end
                end
                buildOpts()

                local function openMenu()
                    isOpen = true; buildOpts()
                    local ap = ddBtn.AbsolutePosition
                    local as = ddBtn.AbsoluteSize
                    local mh = math.min(#opts * ROW_H, MAX_H)
                    menu.Position = UDim2.fromOffset(ap.X, ap.Y + as.Y + 4)
                    menu.Size     = UDim2.fromOffset(as.X, 0)
                    menu.Visible  = true
                    TweenService:Create(menu,  T_MED,   { Size=UDim2.fromOffset(as.X, mh) }):Play()
                    TweenService:Create(arrow, T_SHORT, { Rotation=180 }):Play()
                end

                ddBtn.MouseButton1Click:Connect(function()
                    if isOpen then closeMenu() else openMenu() end
                end)

                UserInputService.InputBegan:Connect(function(inp)
                    if isOpen and inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        local mp = inp.Position
                        local function inBox(ax,ay,aw,ah) return mp.X>=ax and mp.X<=ax+aw and mp.Y>=ay and mp.Y<=ay+ah end
                        local mPos, mSz = menu.AbsolutePosition, menu.AbsoluteSize
                        local bPos, bSz = ddBtn.AbsolutePosition, ddBtn.AbsoluteSize
                        if not inBox(mPos.X,mPos.Y,mSz.X,mSz.Y) and not inBox(bPos.X,bPos.Y,bSz.X,bSz.Y) then closeMenu() end
                    end
                end)

                local DD = {}
                function DD:Set(v) selected=v; ddVal.Text=v; buildOpts(); cb(v) end
                function DD:Get() return selected end
                function DD:Refresh(newOpts) opts=newOpts; buildOpts() end
                return DD
            end

            -- ── BUTTON ───────────────────────────────────────────────────────
            function Section:CreateButton(cfg2)
                cfg2 = cfg2 or {}
                local nm    = cfg2.Name    or "Button"
                local style = cfg2.Style   or "Default"
                local cb    = cfg2.Callback or function() end
                local bgCol = style=="Danger" and Color3.fromRGB(255,245,245) or style=="Outline" and C.WHITE or style=="RGB" and C.WHITE or Color3.fromRGB(22,22,22)
                local txCol = style=="Default" and C.WHITE or style=="Danger" and Color3.fromRGB(210,50,50) or C.T_PRI
                local btn = New("TextButton", { Size=UDim2.new(1,0,0,32), BackgroundColor3=bgCol, Text="", ZIndex=14, Parent=card })
                Corner(7, btn)
                if style=="Default" then Stroke(1, Color3.fromRGB(30,30,30), btn)
                elseif style=="Outline" then Stroke(1, Color3.fromRGB(210,210,210), btn)
                elseif style=="Danger"  then Stroke(1, Color3.fromRGB(252,202,202), btn)
                elseif style=="RGB"     then local s=Stroke(1.5, Color3.fromRGB(255,0,0), btn); AddRGB(s, "Color") end
                New("TextLabel", { Size=UDim2.fromScale(1,1), BackgroundTransparency=1, Text=nm, Font=Enum.Font.GothamMedium, TextSize=13, TextColor3=txCol, ZIndex=15, Parent=btn })
                btn.MouseButton1Down:Connect(function() TweenService:Create(btn, T_SHORT, { Size=UDim2.new(1,-6,0,30) }):Play() end)
                btn.MouseButton1Up:Connect(function()   TweenService:Create(btn, T_SHORT, { Size=UDim2.new(1,0,0,32) }):Play(); cb() end)
            end

            -- ── INPUT ────────────────────────────────────────────────────────
            function Section:CreateInput(cfg2)
                cfg2 = cfg2 or {}
                local nm, ph, cb = cfg2.Name or "Input", cfg2.Placeholder or "Type here...", cfg2.Callback or function() end
                local cont = New("Frame", { Size=UDim2.new(1,0,0,46), BackgroundTransparency=1, ZIndex=14, Parent=card })
                New("TextLabel", { Size=UDim2.new(1,0,0,18), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=12, TextColor3=C.T_HINT, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15, Parent=cont })
                local box = New("TextBox", { Position=UDim2.fromOffset(0,22), Size=UDim2.new(1,0,0,26), BackgroundColor3=Color3.fromRGB(248,248,248), PlaceholderText=ph, PlaceholderColor3=Color3.fromRGB(195,195,195), Text="", Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ClearTextOnFocus=false, ZIndex=15, Parent=cont })
                Corner(6, box); Pad(0, 10, 0, 10, box)
                local bs = Stroke(1, Color3.fromRGB(225,225,225), box)
                box.Focused:Connect(function()    TweenService:Create(bs, T_SHORT, { Color=Color3.fromRGB(0,176,255), Thickness=1.5 }):Play() end)
                box.FocusLost:Connect(function(e) TweenService:Create(bs, T_SHORT, { Color=Color3.fromRGB(225,225,225), Thickness=1 }):Play(); if e then cb(box.Text) end end)
                local INP = {}
                function INP:Set(v) box.Text = v end
                function INP:Get() return box.Text end
                return INP
            end

            -- ── KEYBIND ──────────────────────────────────────────────────────
            function Section:CreateKeybind(cfg2)
                cfg2 = cfg2 or {}
                local nm, def, cb = cfg2.Name or "Keybind", cfg2.Default or Enum.KeyCode.Unknown, cfg2.Callback or function() end
                local row = New("Frame", { Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, ZIndex=14, Parent=card })
                New("TextLabel", { Size=UDim2.new(1,-90,1,0), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15, Parent=row })
                local kbtn = New("TextButton", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.fromOffset(80,22), BackgroundColor3=Color3.fromRGB(244,244,244), Text=def.Name, Font=Enum.Font.Code, TextSize=11, TextColor3=C.T_SEC, ZIndex=15, Parent=row })
                Corner(5, kbtn); Stroke(1, Color3.fromRGB(218,218,218), kbtn)
                New("Frame", { AnchorPoint=Vector2.new(0.5,0), Position=UDim2.new(0.5,0,1,0), Size=UDim2.new(1,0,0,2), BackgroundColor3=Color3.fromRGB(200,200,200), BorderSizePixel=0, ZIndex=14, Parent=kbtn })
                local listening, cur = false, def
                kbtn.MouseButton1Click:Connect(function() listening=true; kbtn.Text="..."; kbtn.TextColor3=Color3.fromRGB(0,176,255) end)
                UserInputService.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.Keyboard then
                        if listening then listening=false; cur=inp.KeyCode; kbtn.Text=inp.KeyCode.Name; kbtn.TextColor3=C.T_SEC; cb(inp.KeyCode)
                        elseif inp.KeyCode == cur then cb(inp.KeyCode) end
                    end
                end)
                local KB = {}
                function KB:Set(k) cur=k; kbtn.Text=k.Name end
                function KB:Get() return cur end
                return KB
            end

            -- ── COLOR PICKER ─────────────────────────────────────────────────
            function Section:CreateColorPicker(cfg2)
                cfg2 = cfg2 or {}
                local nm, def, cb = cfg2.Name or "Color", cfg2.Default or Color3.fromRGB(255,0,0), cfg2.Callback or function() end
                local h, s, v = Color3.toHSV(def)
                local expanded = false
                local cont = New("Frame", { Size=UDim2.new(1,0,0,28), BackgroundTransparency=1, ClipsDescendants=false, ZIndex=14, Parent=card })
                New("TextLabel", { Size=UDim2.new(1,-50,1,0), BackgroundTransparency=1, Text=nm, Font=Enum.Font.Gotham, TextSize=13, TextColor3=C.T_PRI, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=15, Parent=cont })
                local preview = New("TextButton", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.fromOffset(38,22), BackgroundColor3=def, Text="", ZIndex=15, Parent=cont })
                Corner(5, preview); Stroke(1, Color3.fromRGB(210,210,210), preview)
                local panel = New("Frame", { Position=UDim2.fromOffset(0,32), Size=UDim2.new(1,0,0,0), BackgroundColor3=Color3.fromRGB(248,248,248), ClipsDescendants=true, ZIndex=15, Parent=cont })
                Corner(8, panel); Stroke(1, Color3.fromRGB(232,232,232), panel); Pad(8, 10, 8, 10, panel)
                local panelVL = VList(6, panel)
                local function mkHSV(lbl, dv, onChg)
                    local f = New("Frame", { Size=UDim2.new(1,0,0,20), BackgroundTransparency=1, ZIndex=16, Parent=panel })
                    New("TextLabel", { Size=UDim2.new(0,12,1,0), BackgroundTransparency=1, Text=lbl, Font=Enum.Font.Code, TextSize=10, TextColor3=C.T_HINT, ZIndex=17, Parent=f })
                    local bg2 = New("Frame", { AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,16,0.5,0), Size=UDim2.new(1,-46,0,4), BackgroundColor3=Color3.fromRGB(225,225,225), ZIndex=16, Parent=f })
                    Corner(2, bg2)
                    local fl2 = New("Frame", { Size=UDim2.fromScale(dv,1), BackgroundColor3=Color3.fromRGB(255,0,0), ZIndex=17, Parent=bg2 })
                    Corner(2, fl2); AddRGB(fl2, "BackgroundColor3")
                    local th2 = New("Frame", { AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(dv,0,0.5,0), Size=UDim2.fromOffset(12,12), BackgroundColor3=C.WHITE, ZIndex=18, Parent=bg2 })
                    Corner(6, th2); Stroke(1, Color3.fromRGB(200,200,200), th2)
                    local vl2 = New("TextLabel", { AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.fromOffset(26,14), BackgroundTransparency=1, Text=tostring(math.floor(dv*100)), Font=Enum.Font.Code, TextSize=10, TextColor3=C.T_HINT, ZIndex=17, Parent=f })
                    local dr2 = false
                    bg2.InputBegan:Connect(function(i)  if i.UserInputType==Enum.UserInputType.MouseButton1 then dr2=true end end)
                    UserInputService.InputEnded:Connect(function(i)   if i.UserInputType==Enum.UserInputType.MouseButton1 then dr2=false end end)
                    UserInputService.InputChanged:Connect(function(i)
                        if dr2 and i.UserInputType==Enum.UserInputType.MouseMovement then
                            local p = math.clamp((i.Position.X - bg2.AbsolutePosition.X) / bg2.AbsoluteSize.X, 0, 1)
                            fl2.Size=UDim2.fromScale(p,1); th2.Position=UDim2.new(p,0,0.5,0); vl2.Text=tostring(math.floor(p*100)); onChg(p)
                        end
                    end)
                end
                mkHSV("H", h, function(p) h=p; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; cb(c) end)
                mkHSV("S", s, function(p) s=p; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; cb(c) end)
                mkHSV("V", v, function(p) v=p; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; cb(c) end)
                preview.MouseButton1Click:Connect(function()
                    expanded = not expanded
                    local th = expanded and (panelVL.AbsoluteContentSize.Y + 20) or 0
                    TweenService:Create(panel, T_MED, { Size=UDim2.new(1,0,0,th) }):Play()
                    TweenService:Create(cont,  T_MED, { Size=UDim2.new(1,0,0, expanded and 28+4+th or 28) }):Play()
                end)
                local CP = {}
                function CP:Set(col) h,s,v=Color3.toHSV(col); preview.BackgroundColor3=col; cb(col) end
                function CP:Get() return preview.BackgroundColor3 end
                return CP
            end

            -- ── LABEL ────────────────────────────────────────────────────────
            function Section:CreateLabel(cfg)
                -- Handle both
                if type(cfg) == "string" then cfg = { Text = cfg } end
                
                local text = cfg.Text or "Label"
                
                local label = New("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    Text = text,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = C.T_SEC,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    ZIndex = 15,
                    Parent = card -- 'card' is the section container in your library
                })
                local LabelObj = {}
                function LabelObj:SetText(newText)
                    label.Text = tostring(newText)
                end
                return LabelObj
            end

            -- ── DIVIDER ──────────────────────────────────────────────────────
            function Section:CreateDivider()
                New("Frame", { Size=UDim2.new(1,0,0,1), BackgroundColor3=C.DIVIDER, BorderSizePixel=0, ZIndex=14, Parent=card })
            end

            return Section
        end -- CreateSection

        return Tab
    end -- CreateTab

    return Window
end -- CreateWindow

return Library

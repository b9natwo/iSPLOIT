-- Constants
local TWEEN_SHORT  = TweenInfo.new(0.18, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local TWEEN_MED    = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local TWEEN_SPRING = TweenInfo.new(0.45, Enum.EasingStyle.Back,  Enum.EasingDirection.Out)

-- RGB cycling state
local rgbHue = 0
local rgbObjects = {}   -- { {obj, prop, type} }
RunService.Heartbeat:Connect(function(dt)
    rgbHue = (rgbHue + dt * 0.18) % 1
    local col = Color3.fromHSV(rgbHue, 1, 1)
    for _, entry in ipairs(rgbObjects) do
        local obj, prop = entry[1], entry[2]
        if obj and obj.Parent then
            if prop == "BackgroundColor3" then obj.BackgroundColor3 = col
            elseif prop == "TextColor3"   then obj.TextColor3 = col
            elseif prop == "ImageColor3"  then obj.ImageColor3 = col
            end
        end
    end
end)

local function AddRGB(obj, prop)
    table.insert(rgbObjects, {obj, prop})
end

-- Utility: Create instance with props
local function New(class, props, children)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do inst[k] = v end
    for _, child in ipairs(children or {}) do child.Parent = inst end
    return inst
end

-- Utility: UICorner shorthand
local function Corner(r, parent)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = parent
    return c
end

local function Stroke(thickness, color, parent)
    local s = Instance.new("UIStroke")
    s.Thickness = thickness or 1
    s.Color = color or Color3.fromRGB(220,220,220)
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function Padding(top, right, bottom, left, parent)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 0)
    p.PaddingRight  = UDim.new(0, right  or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft   = UDim.new(0, left   or 0)
    p.Parent = parent
    return p
end

local function ListLayout(dir, pad, parent)
    local l = Instance.new("UIListLayout")
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.Padding = UDim.new(0, pad or 4)
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.Parent = parent
    return l
end

-- Auto-size a frame to its content
local function AutoSize(frame, layout)
    layout.Changed:Connect(function()
        frame.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y + 8)
    end)
end

-- Dragging
local function MakeDraggable(handle, frame)
    local dragging, dragStart, startPos = false, nil, nil
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = input.Position
            startPos  = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- Hover tween helper
local function HoverTween(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TWEEN_SHORT, {BackgroundColor3 = hoverColor}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TWEEN_SHORT, {BackgroundColor3 = normalColor}):Play()
    end)
end

-- ============================================================
-- INTRO SCREEN
-- ============================================================
local function PlayIntro(screenGui, onComplete)
    local overlay = New("Frame", {
        Name = "IntroOverlay",
        Size = UDim2.fromScale(1, 1),
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        ZIndex = 100,
        Parent = screenGui
    })

    -- Spiral container (ImageLabel with rotation)
    local spiralHolder = New("Frame", {
        Name = "SpiralHolder",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.45, 0),
        Size = UDim2.fromOffset(120, 120),
        BackgroundTransparency = 1,
        ZIndex = 101,
        Parent = overlay
    })

    -- Three concentric ring images built from frames + UICorner (no asset needed)
    local ringData = {
        {size=120, thick=4, dashCount=6},
        {size=84,  thick=3, dashCount=4},
        {size=52,  thick=2.5, dashCount=3},
    }
    local rings = {}
    for i, rd in ipairs(ringData) do
        -- We simulate a spinning ring via a Frame with UICorner and UIStroke
        local ring = New("Frame", {
            Name = "Ring"..i,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.fromOffset(rd.size, rd.size),
            BackgroundTransparency = 1,
            ZIndex = 101,
            Parent = spiralHolder
        })
        -- Arc approximation: a square frame rotated with visible stroke
        local arc = New("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.fromOffset(rd.size, rd.size),
            BackgroundTransparency = 1,
            ZIndex = 101,
            Parent = ring
        })
        Corner(rd.size / 2, arc)
        local stroke = Stroke(rd.thick, Color3.fromRGB(255, 0, 0), arc)
        AddRGB(stroke, nil)  -- special handling below
        stroke.Transparency = 0.2

        rings[i] = {frame = arc, stroke = stroke, speed = (i % 2 == 0 and -1 or 1) * (1.2 + i * 0.4)}
    end

    -- RGB strokes manually (UIStroke doesn't have a Color3Value property we can tween easily,
    -- so we hook them into the rgbObjects table differently)
    for _, r in ipairs(rings) do
        local s = r.stroke
        table.insert(rgbObjects, {s, "Color"})
        -- patch: UIStroke uses .Color not BackgroundColor3
        -- override via RunService connection
    end

    -- Override rgb handler for UIStroke
    RunService.Heartbeat:Connect(function()
        local col = Color3.fromHSV(rgbHue, 1, 1)
        for _, r in ipairs(rings) do
            if r.stroke and r.stroke.Parent then
                r.stroke.Color = col
            end
        end
    end)

    -- Spin the rings
    local spinConn
    spinConn = RunService.Heartbeat:Connect(function(dt)
        for _, r in ipairs(rings) do
            if r.frame and r.frame.Parent then
                r.frame.Rotation = r.frame.Rotation + r.speed * dt * 120
            end
        end
    end)

    -- Logo text
    local logoLabel = New("TextLabel", {
        Name = "Logo",
        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.new(0.5, 0, 0.45, 72),
        Size = UDim2.fromOffset(220, 36),
        BackgroundTransparency = 1,
        Text = "iSPLOIT",
        Font = Enum.Font.Code,
        TextSize = 28,
        TextColor3 = Color3.fromRGB(255, 0, 0),
        ZIndex = 101,
        Parent = overlay
    })
    AddRGB(logoLabel, "TextColor3")

    local subLabel = New("TextLabel", {
        Name = "Sub",
        AnchorPoint = Vector2.new(0.5, 0),
        Position = UDim2.new(0.5, 0, 0.45, 110),
        Size = UDim2.fromOffset(220, 20),
        BackgroundTransparency = 1,
        Text = "UI LIBRARY  v1.0",
        Font = Enum.Font.GothamMedium,
        TextSize = 10,
        TextColor3 = Color3.fromRGB(180, 180, 180),
        ZIndex = 101,
        Parent = overlay
    })

    -- Fade out after delay
    task.delay(2.6, function()
        spinConn:Disconnect()
        TweenService:Create(overlay, TweenInfo.new(0.6, Enum.EasingStyle.Quart), {
            BackgroundTransparency = 1
        }):Play()
        TweenService:Create(logoLabel, TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        TweenService:Create(subLabel,  TweenInfo.new(0.5), {TextTransparency = 1}):Play()
        for _, r in ipairs(rings) do
            TweenService:Create(r.stroke, TweenInfo.new(0.5), {Transparency = 1}):Play()
        end
        task.delay(0.65, function()
            overlay:Destroy()
            if onComplete then onComplete() end
        end)
    end)
end


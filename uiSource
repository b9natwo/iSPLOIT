                    ZIndex = 6,
                    Parent = row
                })

                local togBg = New("TextButton", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.fromOffset(40, 22),
                    BackgroundColor3 = default and Color3.fromRGB(0, 200, 100) or Color3.fromRGB(220, 220, 220),
                    Text = "",
                    ZIndex = 6,
                    Parent = row
                })
                Corner(11, togBg)

                local togThumb = New("Frame", {
                    AnchorPoint = Vector2.new(0, 0.5),
                    Position = UDim2.fromOffset(default and 20 or 2, 11),
                    Size = UDim2.fromOffset(18, 18),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    ZIndex = 7,
                    Parent = togBg
                })
                Corner(9, togThumb)

                local state = default
                if state then AddRGB(togBg, "BackgroundColor3") end

                togBg.MouseButton1Click:Connect(function()
                    state = not state
                    if state then
                        AddRGB(togBg, "BackgroundColor3")
                        TweenService:Create(togThumb, TWEEN_SPRING, {Position = UDim2.fromOffset(20, 11)}):Play()
                    else
                        -- Remove from rgb list
                        for i = #rgbObjects, 1, -1 do
                            if rgbObjects[i][1] == togBg then table.remove(rgbObjects, i) end
                        end
                        TweenService:Create(togBg, TWEEN_SHORT, {BackgroundColor3 = Color3.fromRGB(220,220,220)}):Play()
                        TweenService:Create(togThumb, TWEEN_SPRING, {Position = UDim2.fromOffset(2, 11)}):Play()
                    end
                    callback(state)
                end)

                local Toggle = {}
                function Toggle:Set(val)
                    state = val
                    togBg.MouseButton1Click:Fire()
                    togBg.MouseButton1Click:Fire() -- toggle back to apply
                    state = val
                    if state then
                        AddRGB(togBg, "BackgroundColor3")
                        togThumb.Position = UDim2.fromOffset(20, 11)
                    else
                        for i = #rgbObjects, 1, -1 do
                            if rgbObjects[i][1] == togBg then table.remove(rgbObjects, i) end
                        end
                        togBg.BackgroundColor3 = Color3.fromRGB(220,220,220)
                        togThumb.Position = UDim2.fromOffset(2, 11)
                    end
                    callback(state)
                end
                function Toggle:Get() return state end
                return Toggle
            end

            -- --------------------------------------------------------
            -- SLIDER
            -- --------------------------------------------------------
            function Section:CreateSlider(config)
                config = config or {}
                local name     = config.Name     or "Slider"
                local min      = config.Min      or 0
                local max      = config.Max      or 100
                local default  = config.Default  or min
                local suffix   = config.Suffix   or ""
                local callback = config.Callback or function() end

                local container = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 44),
                    BackgroundTransparency = 1,
                    ZIndex = 5,
                    Parent = card
                })
                -- Top row: name + value
                local topRow = New("Frame", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    ZIndex = 6,
                    Parent = container
                })
                New("TextLabel", {
                    Size = UDim2.new(1, -60, 1, 0),
                    BackgroundTransparency = 1,
                    Text = name,
                    Font = Enum.Font.Gotham,
                    TextSize = 13,
                    TextColor3 = Color3.fromRGB(50, 50, 50),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 7,
                    Parent = topRow
                })
                local valLabel = New("TextLabel", {
                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.fromScale(1, 0),
                    Size = UDim2.fromOffset(60, 20),
                    BackgroundTransparency = 1,
                    Text = tostring(default)..suffix,
                    Font = Enum.Font.Code,
                    TextSize = 11,
                    TextColor3 = Color3.fromRGB(160, 160, 160),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 7,
                    Parent = topRow
                })

                -- Track
                local trackBg = New("Frame", {
                    AnchorPoint = Vector2.new(0, 0),
                    Position = UDim2.fromOffset(0, 26),
                    Size = UDim2.new(1, 0, 0, 4),
                    BackgroundColor3 = Color3.fromRGB(230, 230, 230),
                    ZIndex = 6,
                    Parent = container
                })
                Corner(2, trackBg)

                local pct = (default - min) / (max - min)
                local trackFill = New("Frame", {
                    Size = UDim2.fromScale(pct, 1),
                    BackgroundColor3 = Color3.fromRGB(255, 0, 0),
                    ZIndex = 7,
                    Parent = trackBg
                })
                Corner(2, trackFill)
                AddRGB(trackFill, "BackgroundColor3")

                local thumb = New("Frame", {
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new(pct, 0, 0.5, 0),
                    Size = UDim2.fromOffset(14, 14),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    ZIndex = 8,
                    Parent = trackBg
                })
                Corner(7, thumb)
                Stroke(1.5, Color3.fromRGB(210,210,210), thumb)

                local value = default
                local dragging = false

                local function updateSlider(absX)
                    local tBounds = trackBg.AbsolutePosition.X
                    local tSize   = trackBg.AbsoluteSize.X
                    local p = math.clamp((absX - tBounds) / tSize, 0, 1)
                    value = math.floor(min + p * (max - min) + 0.5)
                    local vp = (value - min) / (max - min)
                    trackFill.Size = UDim2.fromScale(vp, 1)
                    thumb.Position = UDim2.new(vp, 0, 0.5, 0)
                    valLabel.Text  = tostring(value)..suffix
                    callback(value)
                end

                trackBg.InputBegan:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        updateSlider(inp.Position.X)
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        updateSlider(inp.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)

                local Slider = {}
                function Slider:Set(val)
                    value = math.clamp(val, min, max)
                    local vp = (value - min) / (max - min)
                    trackFill.Size = UDim2.fromScale(vp, 1)
                    thumb.Position = UDim2.new(vp, 0, 0.5, 0)
                    valLabel.Text  = tostring(value)..suffix
                    callback(value)
                end
                function Slider:Get() return value end
                return Slider
            end


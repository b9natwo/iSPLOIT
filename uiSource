                    AnchorPoint = Vector2.new(1, 0),
                    Position = UDim2.new(1, 0, 1, 4),
                    Size = UDim2.new(0.58, 0, 0, 0),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 20,
                    Parent = container
                })
                Corner(8, menuFrame)
                Stroke(1, Color3.fromRGB(225, 225, 225), menuFrame)

                local menuList = ListLayout(Enum.FillDirection.Vertical, 0, menuFrame)

                local function buildMenu()
                    for _, child in ipairs(menuFrame:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    for _, opt in ipairs(options) do
                        local optBtn = New("TextButton", {
                            Size = UDim2.new(1, 0, 0, 28),
                            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                            BackgroundTransparency = opt == ddValLabel.Text and 0.9 or 1,
                            Text = "",
                            ZIndex = 21,
                            Parent = menuFrame
                        })
                        Padding(0, 10, 0, 10, optBtn)
                        New("TextLabel", {
                            Size = UDim2.fromScale(1, 1),
                            BackgroundTransparency = 1,
                            Text = opt,
                            Font = opt == ddValLabel.Text and Enum.Font.GothamMedium or Enum.Font.Gotham,
                            TextSize = 12,
                            TextColor3 = opt == ddValLabel.Text and Color3.fromRGB(30,30,30) or Color3.fromRGB(80,80,80),
                            TextXAlignment = Enum.TextXAlignment.Left,
                            ZIndex = 22,
                            Parent = optBtn
                        })
                        HoverTween(optBtn, Color3.fromRGB(255,255,255), Color3.fromRGB(248,248,248))
                        optBtn.MouseButton1Click:Connect(function()
                            ddValLabel.Text = opt
                            callback(opt)
                            TweenService:Create(menuFrame, TWEEN_SHORT, {Size = UDim2.new(0.58,0,0,0)}):Play()
                            task.delay(0.2, function() menuFrame.Visible = false end)
                            TweenService:Create(arrowLabel, TWEEN_SHORT, {Rotation = 0}):Play()
                            buildMenu()
                        end)
                    end
                    menuFrame.Size = UDim2.new(0.58, 0, 0, math.min(#options * 28, 140))
                end

                local open = false
                ddBtn.MouseButton1Click:Connect(function()
                    open = not open
                    if open then
                        buildMenu()
                        menuFrame.Visible = true
                        menuFrame.Size = UDim2.new(0.58, 0, 0, 0)
                        TweenService:Create(menuFrame, TWEEN_MED, {
                            Size = UDim2.new(0.58, 0, 0, math.min(#options * 28, 140))
                        }):Play()
                        TweenService:Create(arrowLabel, TWEEN_SHORT, {Rotation = 180}):Play()
                    else
                        TweenService:Create(menuFrame, TWEEN_SHORT, {Size = UDim2.new(0.58,0,0,0)}):Play()
                        task.delay(0.2, function() menuFrame.Visible = false end)
                        TweenService:Create(arrowLabel, TWEEN_SHORT, {Rotation = 0}):Play()
                    end
                end)

                local Dropdown = {}
                function Dropdown:Set(val) ddValLabel.Text = val; buildMenu(); callback(val) end
                function Dropdown:Get() return ddValLabel.Text end
                function Dropdown:Refresh(newOptions) options = newOptions; buildMenu() end
                return Dropdown
            end


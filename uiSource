--// iSPLOIT UI LIBRARY (FIXED + LIGHT/DARK + SMOOTH)

local Library = {}
Library.__index = Library

-- Services
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

-- Smooth tweens (slightly improved)
local T_SHORT = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local T_MED   = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local T_SPRING= TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

-- Theme system
local Theme = {
    Dark = false
}

local function ApplyTheme(obj)
    if not obj then return end
    if Theme.Dark then
        if obj:IsA("Frame") then obj.BackgroundColor3 = Color3.fromRGB(30,30,30) end
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then obj.TextColor3 = Color3.fromRGB(220,220,220) end
    else
        if obj:IsA("Frame") then obj.BackgroundColor3 = Color3.fromRGB(250,250,250) end
        if obj:IsA("TextLabel") or obj:IsA("TextButton") then obj.TextColor3 = Color3.fromRGB(30,30,30) end
    end
end

-- Helpers
local function New(c,p)
    local i = Instance.new(c)
    for k,v in pairs(p or {}) do i[k]=v end
    return i
end

local function Corner(r,p)
    local c=Instance.new("UICorner")
    c.CornerRadius=UDim.new(0,r or 6)
    c.Parent=p
end

local function VList(g,p)
    local l=Instance.new("UIListLayout")
    l.Padding=UDim.new(0,g or 4)
    l.Parent=p
    return l
end

-- Window
function Library:CreateWindow(title)
    local gui = New("ScreenGui",{Name="iSPLOIT",Parent=CoreGui})
    local win = New("Frame",{
        Size=UDim2.fromOffset(550,420),
        Position=UDim2.fromScale(0.5,0.5),
        AnchorPoint=Vector2.new(0.5,0.5),
        Parent=gui
    })
    Corner(10,win)

    local Window = {}
    local Tabs = {}

    function Window:ToggleTheme()
        Theme.Dark = not Theme.Dark
        for _,obj in ipairs(win:GetDescendants()) do
            ApplyTheme(obj)
        end
    end

    function Window:CreateTab(name)
        local page = New("Frame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Parent=win})
        local Tab = {}

        function Tab:CreateSection(secName)
            local card = New("Frame",{
                Size=UDim2.new(1,0,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                Parent=page
            })
            Corner(8,card)
            VList(6,card)

            local title = New("TextLabel",{
                Text=secName,
                Size=UDim2.new(1,0,0,20),
                BackgroundTransparency=1,
                Parent=card
            })

            local Section = {}
            Section._Container = card

            -- Toggle
            function Section:CreateToggle(cfg)
                local row = New("Frame",{Size=UDim2.new(1,0,0,30),Parent=self._Container})
                local btn = New("TextButton",{Size=UDim2.fromOffset(40,20),Parent=row})
                local state = cfg.Default or false

                btn.MouseButton1Click:Connect(function()
                    state = not state
                    TweenService:Create(btn,T_SHORT,{Size=UDim2.fromOffset(state and 44 or 40,20)}):Play()
                    cfg.Callback(state)
                end)
            end

            -- Slider
            function Section:CreateSlider(cfg)
                local row = New("Frame",{Size=UDim2.new(1,0,0,40),Parent=self._Container})
                local bar = New("Frame",{Size=UDim2.new(1,0,0,4),Position=UDim2.new(0,0,0,30),Parent=row})
                local fill = New("Frame",{Size=UDim2.new(0,0,1,0),Parent=bar})

                bar.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        local p = (i.Position.X-bar.AbsolutePosition.X)/bar.AbsoluteSize.X
                        fill.Size = UDim2.fromScale(p,1)
                        cfg.Callback(math.floor(p*(cfg.Max-cfg.Min)+cfg.Min))
                    end
                end)
            end

            -- Button
            function Section:CreateButton(cfg)
                local btn = New("TextButton",{
                    Size=UDim2.new(1,0,0,30),
                    Text=cfg.Name,
                    Parent=self._Container
                })
                btn.MouseButton1Click:Connect(cfg.Callback)
            end

            -- ColorPicker (simple)
            function Section:CreateColorPicker(cfg)
                local btn = New("TextButton",{
                    Size=UDim2.new(1,0,0,30),
                    Text=cfg.Name,
                    Parent=self._Container
                })
                btn.MouseButton1Click:Connect(function()
                    cfg.Callback(Color3.fromRGB(math.random(255),math.random(255),math.random(255)))
                end)
            end

            return Section
        end

        return Tab
    end

    return Window
end

return Library

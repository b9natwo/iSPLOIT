                })
                Corner(5, preview)
                Stroke(1, Color3.fromRGB(210,210,210), preview)

                -- Expanded panel
                local panel = New("Frame", {
                    Position = UDim2.fromOffset(0, 34),
                    Size = UDim2.new(1, 0, 0, 0),
                    BackgroundColor3 = Color3.fromRGB(248, 248, 248),
                    ClipsDescendants = true,
                    ZIndex = 6,
                    Parent = container
                })
                Corner(8, panel)
                Stroke(1, Color3.fromRGB(230,230,230), panel)
                Padding(8, 10, 8, 10, panel)
                local panelLayout = ListLayout(Enum.FillDirection.Vertical, 6, panel)

                local function mkHSVSlider(label, defVal, cb)
                    local f = New("Frame", {Size=UDim2.new(1,0,0,20), BackgroundTransparency=1, ZIndex=7, Parent=panel})
                    New("TextLabel",{Size=UDim2.new(0,14,1,0),BackgroundTransparency=1,Text=label,Font=Enum.Font.Code,TextSize=10,TextColor3=Color3.fromRGB(160,160,160),ZIndex=8,Parent=f})
                    local bg = New("Frame",{Position=UDim2.fromOffset(18,0),Size=UDim2.new(1,-50,0,4),AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,18,0.5,0),BackgroundColor3=Color3.fromRGB(225,225,225),ZIndex=7,Parent=f})
                    Corner(2,bg)
                    local fill = New("Frame",{Size=UDim2.fromScale(defVal,1),BackgroundColor3=Color3.fromRGB(255,0,0),ZIndex=8,Parent=bg})
                    Corner(2,fill)
                    AddRGB(fill,"BackgroundColor3")
                    local thumb2 = New("Frame",{AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(defVal,0,0.5,0),Size=UDim2.fromOffset(12,12),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=9,Parent=bg})
                    Corner(6,thumb2)
                    Stroke(1,Color3.fromRGB(200,200,200),thumb2)
                    local vl = New("TextLabel",{AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,0,0.5,0),Size=UDim2.fromOffset(28,16),BackgroundTransparency=1,Text=math.floor(defVal*100).."",Font=Enum.Font.Code,TextSize=10,TextColor3=Color3.fromRGB(150,150,150),ZIndex=8,Parent=f})
                    local drag2 = false
                    bg.InputBegan:Connect(function(inp)
                        if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag2=true end
                    end)
                    UserInputService.InputEnded:Connect(function(inp)
                        if inp.UserInputType==Enum.UserInputType.MouseButton1 then drag2=false end
                    end)
                    UserInputService.InputChanged:Connect(function(inp)
                        if drag2 and inp.UserInputType==Enum.UserInputType.MouseMovement then
                            local p=math.clamp((inp.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
                            fill.Size=UDim2.fromScale(p,1)
                            thumb2.Position=UDim2.new(p,0,0.5,0)
                            vl.Text=math.floor(p*100)
                            cb(p)
                        end
                    end)
                end

                mkHSVSlider("H", h, function(val) h=val; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; callback(c) end)
                mkHSVSlider("S", s, function(val) s=val; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; callback(c) end)
                mkHSVSlider("V", v, function(val) v=val; local c=Color3.fromHSV(h,s,v); preview.BackgroundColor3=c; callback(c) end)

                preview.MouseButton1Click:Connect(function()
                    expanded = not expanded
                    local targetH = expanded and (panelLayout.AbsoluteContentSize.Y + 20) or 0
                    TweenService:Create(panel, TWEEN_MED, {Size = UDim2.new(1,0,0,targetH)}):Play()
                    TweenService:Create(container, TWEEN_MED, {Size = UDim2.new(1,0,0, expanded and 30+4+targetH or 30)}):Play()
                end)

                local ColorPicker = {}
                function ColorPicker:Set(col)
                    h,s,v = Color3.toHSV(col)
                    preview.BackgroundColor3 = col
                    callback(col)
                end
                function ColorPicker:Get() return preview.BackgroundColor3 end
                return ColorPicker
            end

            -- --------------------------------------------------------
            -- LABEL
            -- --------------------------------------------------------
            function Section:CreateLabel(text)
                New("TextLabel", {
                    Size = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text = text,
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Color3.fromRGB(160, 160, 160),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    ZIndex = 5,
                    Parent = card
                })
            end

            -- --------------------------------------------------------
            -- DIVIDER
            -- --------------------------------------------------------
            function Section:CreateDivider()
                New("Frame", {
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = Color3.fromRGB(235, 235, 235),
                    BorderSizePixel = 0,
                    ZIndex = 5,
                    Parent = card
                })
            end

            return Section
        end -- CreateSection

        return Tab
    end -- CreateTab

    -- Notify shorthand on window
    function Window:Notify(t, b, d) return self:Notify(t, b, d) end
    -- Recreate to avoid recursion:
    local _notify = Window.Notify
    Window.Notify = function(self, t, b, d)
        local notif = New("Frame", {
            Size = UDim2.fromOffset(280, 64),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            ClipsDescendants = true,
            ZIndex = 201,
            Parent = notifLayer
        })
        Corner(10, notif)
        Stroke(1, Color3.fromRGB(225, 225, 225), notif)
        local accent = New("Frame", {Size=UDim2.new(0,3,1,0),BackgroundColor3=Color3.fromRGB(255,0,0),BorderSizePixel=0,ZIndex=202,Parent=notif})
        Corner(2, accent)
        AddRGB(accent, "BackgroundColor3")
        New("TextLabel",{Position=UDim2.fromOffset(14,10),Size=UDim2.new(1,-22,0,18),BackgroundTransparency=1,Text=t or "",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=Color3.fromRGB(30,30,30),TextXAlignment=Enum.TextXAlignment.Left,ZIndex=202,Parent=notif})
        New("TextLabel",{Position=UDim2.fromOffset(14,30),Size=UDim2.new(1,-22,0,28),BackgroundTransparency=1,Text=b or "",Font=Enum.Font.Gotham,TextSize=11,TextColor3=Color3.fromRGB(120,120,120),TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=202,Parent=notif})
        local prog = New("Frame",{AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,3,1,0),Size=UDim2.new(1,-3,0,2),BackgroundColor3=Color3.fromRGB(255,0,0),BorderSizePixel=0,ZIndex=202,Parent=notif})
        AddRGB(prog,"BackgroundColor3")
        local dur = d or 3
        TweenService:Create(prog, TweenInfo.new(dur, Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,0,2)}):Play()
        notif.Position = UDim2.fromOffset(300, 0)
        TweenService:Create(notif, TWEEN_MED, {Position=UDim2.fromOffset(0,0)}):Play()
        task.delay(dur, function()
            TweenService:Create(notif, TWEEN_MED, {Position=UDim2.fromOffset(300,0)}):Play()
            task.delay(0.4, function() notif:Destroy() end)
        end)
    end

    -- Toggle visibility with a key
    function Window:BindToggleKey(key)
        key = key or Enum.KeyCode.RightShift
        UserInputService.InputBegan:Connect(function(inp, gp)
            if not gp and inp.KeyCode == key then
                mainFrame.Visible = not mainFrame.Visible
            end
        end)
    end

    function Window:Destroy()
        screenGui:Destroy()
    end

    return Window
end

return Library
